DATABASE_URL=postgres://user:password@localhost:5432/yos_caribbean_kitchen
# Set to true for hosted Postgres providers that require SSL.
DATABASE_SSL=false
# Set to false for local `next start` over http://localhost.
AUTH_COOKIE_SECURE=false
# Required for private menu admin endpoints. Use a long random value.
ADMIN_API_KEY=change-me
# Required to sync menu items into Stripe products/prices.
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
STRIPE_CURRENCY=usd
# Public deployed website URL used to sync relative product images to Stripe.
NEXT_PUBLIC_SITE_URL=https://eatyos.com
# Optional override if Stripe should load product images from a different public URL.
STRIPE_IMAGE_BASE_URL=https://eatyos.com
# Optional persistent upload target for admin menu image uploads in production.
# MENU_IMAGE_UPLOAD_DIR=/app/public/menu-images
# MENU_IMAGE_PUBLIC_PATH=/menu-images
